{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/research.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/download-pdf.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/discord-test.ts": {
      "maxDuration": 30
    }
  }
}
