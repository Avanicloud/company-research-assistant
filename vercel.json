{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/research.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/download-pdf.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/discord-test.js": {
      "maxDuration": 30
    },
    "api/config-status.js": {
      "maxDuration": 15,
      "memory": 512
    },
    "api/health.js": {
      "maxDuration": 15,
      "memory": 512
    }
  }
}
